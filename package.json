{
  "name": "social-ai-web",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "social-ai customer Dashboard frontend (P5b) — Vite + TanStack Router SPA over the Dashboard API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
