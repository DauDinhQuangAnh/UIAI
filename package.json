    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-virtual": "^3.14.2",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
